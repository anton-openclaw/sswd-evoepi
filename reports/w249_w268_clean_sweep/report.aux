\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}RMSE Ranking}{2}{subsection.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces RMSE ranking for all 20 configurations (W249--W268). W257 (fw=25, $K_{\text  {half}}$=1.2M) achieves the lowest RMSE of 0.697. The bottom two configurations (W256, W258) both use $K_{\text  {half}}$=400K, confirming that reducing carrying capacity is catastrophic under the corrected code.}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:rmse}{{1}{3}{RMSE ranking for all 20 configurations (W249--W268). W257 (fw=25, $K_{\text {half}}$=1.2M) achieves the lowest RMSE of 0.697. The bottom two configurations (W256, W258) both use $K_{\text {half}}$=400K, confirming that reducing carrying capacity is catastrophic under the corrected code}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Regional Recovery Heatmap}{3}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Regional recovery heatmap. Rows are configurations (sorted by RMSE), columns are regions (north to south). W257 stands out with the highest recovery in AK-PWS (12.1\%), AK-FN (6.3\%), and AK-AL (19.7\%). The $K_{\text  {half}}$=400K configurations (W256, W258) show near-zero recovery everywhere except AK-AL.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:heatmap}{{2}{4}{Regional recovery heatmap. Rows are configurations (sorted by RMSE), columns are regions (north to south). W257 stands out with the highest recovery in AK-PWS (12.1\%), AK-FN (6.3\%), and AK-AL (19.7\%). The $K_{\text {half}}$=400K configurations (W256, W258) show near-zero recovery everywhere except AK-AL}{figure.caption.4}{}}
