  "model_equations": {
    "ocean_baseline": "S_ocean(lat) = 31.32 + 0.054 * (lat - 50.0)",
    "depression": "delta_S = fw_strength * fd_norm^fw_depth_exp * f_melt(lat) * melt_pulse(day)",
    "melt_pulse": "melt_pulse(day) = max(0, cos(2*pi*(day - 166)/365))",
    "latitude_melt_factor": "f_melt(lat) = clip((lat - 35) / 25, 0, 1)",
    "salinity": "S(site, day) = max(s_floor, S_ocean - delta_S)",
    "sal_mod": "sal_mod(S) = ((S - s_min) / (s_full - s_min))^eta, clipped [0,1]",
    "s_floor": 5.0,
    "s_min": 10.0,
    "s_full": 28.0,
    "eta": 2.0,
    "peak_day": 166
  },
  "parameter_ranges": {
