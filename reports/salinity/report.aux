\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Mean June Vibrio suppression (\%) by region at \texttt  {fw\_strength}~=~15, ordered north to south. The gradient from AK-FN (73.7\%) through BC to zero suppression south of the Salish Sea is clearly visible.}}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:suppression_bars}{{6}{8}{Mean June Vibrio suppression (\%) by region at \texttt {fw\_strength}~=~15, ordered north to south. The gradient from AK-FN (73.7\%) through BC to zero suppression south of the Salish Sea is clearly visible}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Seasonal Dynamics}{8}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Seasonal salinity curves by region at \texttt  {fw\_strength}~=~15. Each curve shows the mean salinity across all nodes in the region. The deepest summer troughs occur in AK-FN (reaching $\sim $19 psu) and SS-N ($\sim $22.5 psu). California and Oregon regions show near-constant salinity year-round.}}{9}{figure.caption.9}\protected@file@percent }
\newlabel{fig:regional_profiles}{{7}{9}{Seasonal salinity curves by region at \texttt {fw\_strength}~=~15. Each curve shows the mean salinity across all nodes in the region. The deepest summer troughs occur in AK-FN (reaching $\sim $19 psu) and SS-N ($\sim $22.5 psu). California and Oregon regions show near-constant salinity year-round}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Geographic maps of Vibrio suppression by month (6 panels covering the melt season). Suppression is concentrated in Alaskan fjords and the Salish Sea, peaking in June--July and disappearing by October.}}{10}{figure.caption.10}\protected@file@percent }
\newlabel{fig:monthly_panels}{{8}{10}{Geographic maps of Vibrio suppression by month (6 panels covering the melt season). Suppression is concentrated in Alaskan fjords and the Salish Sea, peaking in June--July and disappearing by October}{figure.caption.10}{}}
