\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Salinity Modifier (Vibrio Response)}{6}{subsection.4.3}\protected@file@percent }
\newlabel{eq:sal_mod}{{5}{6}{Salinity Modifier (Vibrio Response)}{equation.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Salinity modifier transfer function ($\texttt  {sal\_mod}$) mapping salinity to \textit  {Vibrio} growth capacity. Key thresholds: $s_{\text  {min}} = 10$ psu (complete suppression), $s_{\text  {full}} = 28$ psu (no limitation). The non-linear ($\eta = 2$) response means most suppression occurs below $\sim $22 psu. Annotated points show representative site salinities.}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:sal_mod}{{4}{6}{Salinity modifier transfer function ($\texttt {sal\_mod}$) mapping salinity to \textit {Vibrio} growth capacity. Key thresholds: $s_{\text {min}} = 10$ psu (complete suppression), $s_{\text {full}} = 28$ psu (no limitation). The non-linear ($\eta = 2$) response means most suppression occurs below $\sim $22 psu. Annotated points show representative site salinities}{figure.caption.5}{}}
