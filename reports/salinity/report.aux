\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Two-panel latitude asymmetry diagnostic at \texttt  {fw\_strength}~=~15. Left: mean June salinity depression (psu) by latitude, showing the strong high-latitude signal driven by fjord depth and melt factor. Right: mean June Vibrio suppression (\%) by latitude, demonstrating the non-linear amplification through the $\texttt  {sal\_mod}$ transfer function.}}{7}{figure.caption.6}\protected@file@percent }
\newlabel{fig:asymmetry}{{5}{7}{Two-panel latitude asymmetry diagnostic at \texttt {fw\_strength}~=~15. Left: mean June salinity depression (psu) by latitude, showing the strong high-latitude signal driven by fjord depth and melt factor. Right: mean June Vibrio suppression (\%) by latitude, demonstrating the non-linear amplification through the $\texttt {sal\_mod}$ transfer function}{figure.caption.6}{}}
