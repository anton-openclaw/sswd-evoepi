\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces Spawning season and immunosuppression. The figure shows the extended spawning season (November--July) with multiple cascading bouts, the 28-day immunosuppression window triggered by each bout (during which susceptibility doubles), and how the overlap between spawning immunosuppression and spring Vibrio resuscitation creates a seasonal window of maximum disease risk.}}{35}{figure.caption.33}\protected@file@percent }
\newlabel{fig:fig_PG07}{{33}{35}{Spawning season and immunosuppression. The figure shows the extended spawning season (November--July) with multiple cascading bouts, the 28-day immunosuppression window triggered by each bout (during which susceptibility doubles), and how the overlap between spawning immunosuppression and spring Vibrio resuscitation creates a seasonal window of maximum disease risk}{figure.caption.33}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.11}Evolutionary Trajectories}{35}{subsection.4.11}\protected@file@percent }
\newlabel{sec:trajectories}{{4.11}{35}{Evolutionary Trajectories}{subsection.4.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces Evolutionary trajectories (W285 simulation). Upper panel: Mean trait values over 12 simulation years. Resistance (blue) increases sharply from 0.150 to 0.177 following epidemic onset ($\sim $year 2), with the fastest change occurring in years 2--4 (inset: rate of trait change peaks at $\sim $0.012/yr around year 3). Tolerance (orange, 0.100) and Recovery (green, 0.020) show no change. Lower panel: Coast-wide population crashes from $\sim $4.5 million to $<$0.5 million following the epidemic, with slow continued decline through year 12.}}{36}{figure.caption.34}\protected@file@percent }
\newlabel{fig:fig_PG09}{{34}{36}{Evolutionary trajectories (W285 simulation). Upper panel: Mean trait values over 12 simulation years. Resistance (blue) increases sharply from 0.150 to 0.177 following epidemic onset ($\sim $year 2), with the fastest change occurring in years 2--4 (inset: rate of trait change peaks at $\sim $0.012/yr around year 3). Tolerance (orange, 0.100) and Recovery (green, 0.020) show no change. Lower panel: Coast-wide population crashes from $\sim $4.5 million to $<$0.5 million following the epidemic, with slow continued decline through year 12}{figure.caption.34}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.12}Latitudinal Variation in Trait Distributions}{37}{subsection.4.12}\protected@file@percent }
\newlabel{sec:latitudinal}{{4.12}{37}{Latitudinal Variation in Trait Distributions}{subsection.4.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces Latitudinal variation in trait distributions (W285, year 0 gray vs.\ year 12 colored). Ridge plots showing population-level trait distributions for all 19 regions ordered south to north. Resistance (left, blue): relatively uniform across latitudes with a modest rightward shift by year 12. Tolerance (middle, orange): shows a latitudinal gradient---southern regions have broader, higher-value distributions. Recovery (right, green): uniformly low and tightly concentrated across all latitudes. The gradient in tolerance likely reflects differential selection pressures imposed by the latitudinal temperature gradient.}}{37}{figure.caption.35}\protected@file@percent }
\newlabel{fig:fig_PG10}{{35}{37}{Latitudinal variation in trait distributions (W285, year 0 gray vs.\ year 12 colored). Ridge plots showing population-level trait distributions for all 19 regions ordered south to north. Resistance (left, blue): relatively uniform across latitudes with a modest rightward shift by year 12. Tolerance (middle, orange): shows a latitudinal gradient---southern regions have broader, higher-value distributions. Recovery (right, green): uniformly low and tightly concentrated across all latitudes. The gradient in tolerance likely reflects differential selection pressures imposed by the latitudinal temperature gradient}{figure.caption.35}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.13}The Fitness Landscape: Why Resistance Dominates}{37}{subsection.4.13}\protected@file@percent }
\newlabel{sec:fitness}{{4.13}{37}{The Fitness Landscape: Why Resistance Dominates}{subsection.4.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces Fitness landscape: resistance versus tolerance. Main panel: contour plot of relative fitness as a function of resistance and tolerance trait values. The fitness gradient is overwhelmingly steeper along the resistance axis. Red star: initial population mean ($\bar  {r} = 0.15$, $\bar  {t} = 0.10$); yellow star: evolved mean ($\bar  {r} = 0.18$, $\bar  {t} = 0.10$)---evolution moves exclusively along the resistance axis. Inset: cross-sections confirming a $\sim $1000$\times $ gradient difference between resistance (steep) and tolerance (nearly flat) at the population's position in trait space.}}{38}{figure.caption.36}\protected@file@percent }
\newlabel{fig:fig_PG12}{{36}{38}{Fitness landscape: resistance versus tolerance. Main panel: contour plot of relative fitness as a function of resistance and tolerance trait values. The fitness gradient is overwhelmingly steeper along the resistance axis. Red star: initial population mean ($\bar {r} = 0.15$, $\bar {t} = 0.10$); yellow star: evolved mean ($\bar {r} = 0.18$, $\bar {t} = 0.10$)---evolution moves exclusively along the resistance axis. Inset: cross-sections confirming a $\sim $1000$\times $ gradient difference between resistance (steep) and tolerance (nearly flat) at the population's position in trait space}{figure.caption.36}{}}
