\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}The 896-Node Metapopulation Network}{4}{subsection.2.1}\protected@file@percent }
\newlabel{sec:network}{{2.1}{4}{The 896-Node Metapopulation Network}{subsection.2.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The 896-node metapopulation network spanning the Pacific coast of North America from Baja California ($\sim $28\textdegree N) to the western Gulf of Alaska ($\sim $62\textdegree N). Nodes are colored by biogeographic region (18 regions total). Inset panels show detail for (top) the SE Alaska fjord complex, (middle) the Puget Sound / Salish Sea region, and (bottom) the Channel Islands / Southern California Bight. Node density varies considerably, reflecting the complexity of coastal habitat---the SE Alaska archipelago and Puget Sound contain particularly dense node clusters.}}{5}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:fig_S01}{{1}{5}{The 896-node metapopulation network spanning the Pacific coast of North America from Baja California ($\sim $28\textdegree N) to the western Gulf of Alaska ($\sim $62\textdegree N). Nodes are colored by biogeographic region (18 regions total). Inset panels show detail for (top) the SE Alaska fjord complex, (middle) the Puget Sound / Salish Sea region, and (bottom) the Channel Islands / Southern California Bight. Node density varies considerably, reflecting the complexity of coastal habitat---the SE Alaska archipelago and Puget Sound contain particularly dense node clusters}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Overwater Distance Computation}{6}{subsection.2.2}\protected@file@percent }
\newlabel{sec:overwater}{{2.2}{6}{Overwater Distance Computation}{subsection.2.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Overwater versus haversine distance. (A)~Log-log scatter of all pairwise overwater versus haversine distances, showing systematic inflation above the 1:1 line. (B)~Example: the Olympic Peninsula forces a 307~km overwater route between two points separated by only 199~km as-the-crow-flies. (C)~Spatial map of the mean distance inflation factor, showing that the most topologically complex coastlines (SE Alaska, BC fjords) produce inflation factors of 3--4$\times $.}}{6}{figure.caption.2}\protected@file@percent }
\newlabel{fig:fig_S12}{{2}{6}{Overwater versus haversine distance. (A)~Log-log scatter of all pairwise overwater versus haversine distances, showing systematic inflation above the 1:1 line. (B)~Example: the Olympic Peninsula forces a 307~km overwater route between two points separated by only 199~km as-the-crow-flies. (C)~Spatial map of the mean distance inflation factor, showing that the most topologically complex coastlines (SE Alaska, BC fjords) produce inflation factors of 3--4$\times $}{figure.caption.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Larval Connectivity Matrix}{6}{subsection.2.3}\protected@file@percent }
\newlabel{sec:larval}{{2.3}{6}{Larval Connectivity Matrix}{subsection.2.3}{}}
\newlabel{eq:larval}{{1}{6}{Larval Connectivity Matrix}{equation.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Larval connectivity matrix $\mathbf  {C}$. (A)~The full 896$\times $896 matrix (log-scale), showing strong diagonal dominance (local retention) with a characteristic bandwidth determined by $D_L = 400$~km. Northern nodes (Alaska) show higher overall connectivity due to the dense fjord network. (B)~Region-aggregated connectivity, revealing that self-recruitment dominates within each region, with moderate inter-regional exchange along the US West Coast but negligible long-distance transport between Alaska and California. (C)~Net larval export map: blue nodes (net exporters) concentrate in Alaska and BC, while orange/red nodes (net importers) dominate the US West Coast.}}{7}{figure.caption.3}\protected@file@percent }
\newlabel{fig:fig_S03}{{3}{7}{Larval connectivity matrix $\mathbf {C}$. (A)~The full 896$\times $896 matrix (log-scale), showing strong diagonal dominance (local retention) with a characteristic bandwidth determined by $D_L = 400$~km. Northern nodes (Alaska) show higher overall connectivity due to the dense fjord network. (B)~Region-aggregated connectivity, revealing that self-recruitment dominates within each region, with moderate inter-regional exchange along the US West Coast but negligible long-distance transport between Alaska and California. (C)~Net larval export map: blue nodes (net exporters) concentrate in Alaska and BC, while orange/red nodes (net importers) dominate the US West Coast}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}Pathogen Dispersal Matrix}{7}{subsection.2.4}\protected@file@percent }
\newlabel{sec:pathogen_dispersal}{{2.4}{7}{Pathogen Dispersal Matrix}{subsection.2.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Pathogen dispersal matrices. (A)~The local exchange matrix ($D_P = 15$~km) is extremely sparse, with connectivity confined to a narrow band along the diagonal---each node interacts with only $\sim $13 effective neighbors (median). (B)~The wavefront matrix ($D_P^{\text  {wave}} = 300$~km) is dramatically denser, connecting each node to $\sim $442 effective neighbors. (C)~Histogram comparing the number of effective neighbors (weight $>0.01$) under each dispersal mode.}}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:fig_S11}{{4}{8}{Pathogen dispersal matrices. (A)~The local exchange matrix ($D_P = 15$~km) is extremely sparse, with connectivity confined to a narrow band along the diagonal---each node interacts with only $\sim $13 effective neighbors (median). (B)~The wavefront matrix ($D_P^{\text {wave}} = 300$~km) is dramatically denser, connecting each node to $\sim $442 effective neighbors. (C)~Histogram comparing the number of effective neighbors (weight $>0.01$) under each dispersal mode}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Enclosedness-Based Flushing}{8}{subsection.2.5}\protected@file@percent }
\newlabel{sec:flushing}{{2.5}{8}{Enclosedness-Based Flushing}{subsection.2.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Enclosedness pipeline. (A)~Raw geometric enclosedness computed from the coastal geometry (high values = enclosed embayments). (B)~Effective enclosedness after smoothing and adjustment. (C)~The nonlinear transfer function converting effective enclosedness to flushing rate: open coasts ($e_{\text  {eff}} \approx 0$) flush at $\sim $0.8~d$^{-1}$, while highly enclosed fjords ($e_{\text  {eff}} \approx 1$) flush at $<$0.05~d$^{-1}$. (D)~Resulting spatial pattern of flushing rates along the coast.}}{9}{figure.caption.5}\protected@file@percent }
\newlabel{fig:fig_S05}{{5}{9}{Enclosedness pipeline. (A)~Raw geometric enclosedness computed from the coastal geometry (high values = enclosed embayments). (B)~Effective enclosedness after smoothing and adjustment. (C)~The nonlinear transfer function converting effective enclosedness to flushing rate: open coasts ($e_{\text {eff}} \approx 0$) flush at $\sim $0.8~d$^{-1}$, while highly enclosed fjords ($e_{\text {eff}} \approx 1$) flush at $<$0.05~d$^{-1}$. (D)~Resulting spatial pattern of flushing rates along the coast}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.6}The Fjord Paradox}{9}{subsection.2.6}\protected@file@percent }
\newlabel{sec:fjord}{{2.6}{9}{The Fjord Paradox}{subsection.2.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces The fjord paradox. (A)~Conceptual diagram: open coasts have low self-recruitment ($\alpha _{\text  {self}} = 0.02$) but rapid flushing ($\varphi = 0.80$); fjords have high self-recruitment ($\alpha _{\text  {self}} = 0.70$) but slow flushing ($\varphi = 0.03$). (B)~Scatter plot of self-recruitment versus pathogen retention time ($1/\varphi $), showing the strong positive correlation: fjord sites retain both larvae and pathogens. (C)~Epidemic outcome space: sites with long pathogen retention experience both higher peak prevalence and longer recovery times.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:fig_S06}{{6}{10}{The fjord paradox. (A)~Conceptual diagram: open coasts have low self-recruitment ($\alpha _{\text {self}} = 0.02$) but rapid flushing ($\varphi = 0.80$); fjords have high self-recruitment ($\alpha _{\text {self}} = 0.70$) but slow flushing ($\varphi = 0.03$). (B)~Scatter plot of self-recruitment versus pathogen retention time ($1/\varphi $), showing the strong positive correlation: fjord sites retain both larvae and pathogens. (C)~Epidemic outcome space: sites with long pathogen retention experience both higher peak prevalence and longer recovery times}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.7}Sea Surface Temperature Forcing}{10}{subsection.2.7}\protected@file@percent }
\newlabel{sec:sst}{{2.7}{10}{Sea Surface Temperature Forcing}{subsection.2.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces SST forcing. (A)~Hovm\"oller diagram showing SST as a function of latitude and time (2002--2025). The strong latitudinal gradient ($\sim $18\textdegree C from Baja to Alaska) and seasonal oscillations are clearly visible, as is the 2014--2016 marine heatwave. (B)~Representative time series from three stations spanning the latitudinal range: Baja ($\sim $15--23\textdegree C), Central California ($\sim $10--16\textdegree C), and SE Alaska ($\sim $4--12\textdegree C). (C)~Map of mean annual SST across all 896 nodes.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:fig_S07}{{7}{11}{SST forcing. (A)~Hovm\"oller diagram showing SST as a function of latitude and time (2002--2025). The strong latitudinal gradient ($\sim $18\textdegree C from Baja to Alaska) and seasonal oscillations are clearly visible, as is the 2014--2016 marine heatwave. (B)~Representative time series from three stations spanning the latitudinal range: Baja ($\sim $15--23\textdegree C), Central California ($\sim $10--16\textdegree C), and SE Alaska ($\sim $4--12\textdegree C). (C)~Map of mean annual SST across all 896 nodes}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.8}Two-Layer Salinity Model}{11}{subsection.2.8}\protected@file@percent }
\newlabel{sec:salinity}{{2.8}{11}{Two-Layer Salinity Model}{subsection.2.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Two-layer salinity model. (A)~WOA23 mean surface salinity along the coast. (B1)~Latitude-dependent freshwater depression amplitude, increasing dramatically above 50\textdegree N. (B2)~Seasonal envelope of the melt pulse for different enclosedness values; more enclosed sites experience sharper, more concentrated freshening. (C)~Combined salinity maps for January, April, July, and October, showing the dramatic summer freshening in Alaskan and BC fjords (salinity dropping below 10~psu).}}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:fig_S08}{{8}{12}{Two-layer salinity model. (A)~WOA23 mean surface salinity along the coast. (B1)~Latitude-dependent freshwater depression amplitude, increasing dramatically above 50\textdegree N. (B2)~Seasonal envelope of the melt pulse for different enclosedness values; more enclosed sites experience sharper, more concentrated freshening. (C)~Combined salinity maps for January, April, July, and October, showing the dramatic summer freshening in Alaskan and BC fjords (salinity dropping below 10~psu)}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.9}Wavefront Disease Spread}{13}{subsection.2.9}\protected@file@percent }
\newlabel{sec:wavefront}{{2.9}{13}{Wavefront Disease Spread}{subsection.2.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Wavefront activation from the Channel Islands origin. Six panels show the progressive spread of the disease wavefront from June 2013 (seed event at the Channel Islands, marked with a yellow star) through February 2016. Nodes transition from gray (inactive) to colored (activated) as the CDT threshold is crossed. Color indicates activation time in months from January 2012. By early 2016, the wavefront has reached from Baja California to the Gulf of Alaska.}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:fig_S04}{{9}{13}{Wavefront activation from the Channel Islands origin. Six panels show the progressive spread of the disease wavefront from June 2013 (seed event at the Channel Islands, marked with a yellow star) through February 2016. Nodes transition from gray (inactive) to colored (activated) as the CDT threshold is crossed. Color indicates activation time in months from January 2012. By early 2016, the wavefront has reached from Baja California to the Gulf of Alaska}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.10}Environmental Vibrio Dynamics}{14}{subsection.2.10}\protected@file@percent }
\newlabel{sec:vibrio_env}{{2.10}{14}{Environmental Vibrio Dynamics}{subsection.2.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Environmental Vibrio dynamics. (A)~Growth versus decay rates as a function of temperature. The Vibrio growth rate increases exponentially with temperature (Arrhenius), while the total decay rate combines natural die-off with flushing ($\varphi $). In fjords ($\varphi = 0.03$), growth exceeds decay above $\sim $5\textdegree C (pink ``Vibrio+ zone''); on open coasts ($\varphi = 0.80$), the high flushing rate suppresses net Vibrio accumulation at all but the warmest temperatures. (B)~Time series of environmental Vibrio proxy at a fjord versus open-coast site, showing more frequent and sustained spikes in the fjord. (C)~Process schematic: the environmental Vibrio pool $P_k$ is fed by host shedding and temperature-dependent growth, and depleted by flushing, natural decay, and dispersal to neighbors.}}{14}{figure.caption.10}\protected@file@percent }
\newlabel{fig:fig_S10}{{10}{14}{Environmental Vibrio dynamics. (A)~Growth versus decay rates as a function of temperature. The Vibrio growth rate increases exponentially with temperature (Arrhenius), while the total decay rate combines natural die-off with flushing ($\varphi $). In fjords ($\varphi = 0.03$), growth exceeds decay above $\sim $5\textdegree C (pink ``Vibrio+ zone''); on open coasts ($\varphi = 0.80$), the high flushing rate suppresses net Vibrio accumulation at all but the warmest temperatures. (B)~Time series of environmental Vibrio proxy at a fjord versus open-coast site, showing more frequent and sustained spikes in the fjord. (C)~Process schematic: the environmental Vibrio pool $P_k$ is fed by host shedding and temperature-dependent growth, and depleted by flushing, natural decay, and dispersal to neighbors}{figure.caption.10}{}}
