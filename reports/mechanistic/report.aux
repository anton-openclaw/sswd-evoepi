\@writefile{toc}{\contentsline {section}{\numberline {3}Disease Dynamics}{16}{section.3}\protected@file@percent }
\newlabel{sec:disease}{{3}{16}{Disease Dynamics}{section.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}The SEIPD+R Compartmental Model}{16}{subsection.3.1}\protected@file@percent }
\newlabel{sec:compartments}{{3.1}{16}{The SEIPD+R Compartmental Model}{subsection.3.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces The SEIPD+R compartmental model. Flow diagram showing disease progression from Susceptible through Exposed, Pre-symptomatic ($\text  {I}_1$), Symptomatic ($\text  {I}_2$), to Dead. All transition rates are temperature-dependent (Arrhenius scaling). Green dashed arrows indicate recovery pathways from E, $\text  {I}_1$, and $\text  {I}_2$ states. Three host genetic traits modify different transitions: Resistance [R] modifies the force of infection (S$\to $E), Tolerance [T] extends $\text  {I}_2$ survival time, and Recovery [C] governs daily clearance probability. The summary table shows state-dependent behavioral parameters (speed, feeding, spawning ability).}}{17}{figure.caption.13}\protected@file@percent }
\newlabel{fig:fig_D01}{{13}{17}{The SEIPD+R compartmental model. Flow diagram showing disease progression from Susceptible through Exposed, Pre-symptomatic ($\text {I}_1$), Symptomatic ($\text {I}_2$), to Dead. All transition rates are temperature-dependent (Arrhenius scaling). Green dashed arrows indicate recovery pathways from E, $\text {I}_1$, and $\text {I}_2$ states. Three host genetic traits modify different transitions: Resistance [R] modifies the force of infection (S$\to $E), Tolerance [T] extends $\text {I}_2$ survival time, and Recovery [C] governs daily clearance probability. The summary table shows state-dependent behavioral parameters (speed, feeding, spawning ability)}{figure.caption.13}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Force of Infection}{17}{subsection.3.2}\protected@file@percent }
\newlabel{sec:foi}{{3.2}{17}{Force of Infection}{subsection.3.2}{}}
\newlabel{eq:foi}{{3}{18}{Force of Infection}{equation.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Force of infection decomposition. (A)~Dose-response: a Michaelis-Menten (saturating) function of environmental Vibrio concentration $P_k$, with half-saturation $K_{\text  {half}} = 1.5 \times 10^6$~bact/mL. (B)~Resistance modifier: susceptibility $(1-r_i)$ is linear in the resistance trait, with the population distribution shown as a Beta(2,8) density. (C)~Salinity modifier $S_{\text  {sal}}$: a quadratic ramp from 0 (below $s_{\text  {min}} = 10$~psu, Vibrio unviable) to 1 (above $s_{\text  {full}} = 28$~psu). (D)~Size-dependent susceptibility: flat at 1.0 for $L < 300$~mm, then increasing linearly at OR = 1.23 per 10~mm, reflecting the empirical observation that larger sea stars are more susceptible to SSWD.}}{18}{figure.caption.14}\protected@file@percent }
\newlabel{fig:fig_D02}{{14}{18}{Force of infection decomposition. (A)~Dose-response: a Michaelis-Menten (saturating) function of environmental Vibrio concentration $P_k$, with half-saturation $K_{\text {half}} = 1.5 \times 10^6$~bact/mL. (B)~Resistance modifier: susceptibility $(1-r_i)$ is linear in the resistance trait, with the population distribution shown as a Beta(2,8) density. (C)~Salinity modifier $S_{\text {sal}}$: a quadratic ramp from 0 (below $s_{\text {min}} = 10$~psu, Vibrio unviable) to 1 (above $s_{\text {full}} = 28$~psu). (D)~Size-dependent susceptibility: flat at 1.0 for $L < 300$~mm, then increasing linearly at OR = 1.23 per 10~mm, reflecting the empirical observation that larger sea stars are more susceptible to SSWD}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Environmental Vibrio Pool Dynamics}{19}{subsection.3.3}\protected@file@percent }
\newlabel{sec:vibrio_pool}{{3.3}{19}{Environmental Vibrio Pool Dynamics}{subsection.3.3}{}}
\newlabel{eq:vibrio}{{4}{19}{Environmental Vibrio Pool Dynamics}{equation.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Environmental Vibrio dynamics at a single node. (A)~Budget schematic showing source terms (host shedding from $\text  {I}_1$, $\text  {I}_2$, and D compartments; environmental reservoir $P_{\text  {env}}$; spatial dispersal) and sink terms (temperature-dependent decay $\xi (T)$; hydrological flushing $\varphi $). (B)~Simulated Vibrio concentration (purple, left axis) and infected count (red bars, right axis) over one year, showing correlated episodic spikes. (C)~Host-amplified environmental pool $P_{\text  {env}}$ dynamics over one year, showing the seasonal buildup driven by temperature and host shedding feedback.}}{19}{figure.caption.15}\protected@file@percent }
\newlabel{fig:fig_D03}{{15}{19}{Environmental Vibrio dynamics at a single node. (A)~Budget schematic showing source terms (host shedding from $\text {I}_1$, $\text {I}_2$, and D compartments; environmental reservoir $P_{\text {env}}$; spatial dispersal) and sink terms (temperature-dependent decay $\xi (T)$; hydrological flushing $\varphi $). (B)~Simulated Vibrio concentration (purple, left axis) and infected count (red bars, right axis) over one year, showing correlated episodic spikes. (C)~Host-amplified environmental pool $P_{\text {env}}$ dynamics over one year, showing the seasonal buildup driven by temperature and host shedding feedback}{figure.caption.15}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}VBNC Dormancy}{19}{subsection.3.4}\protected@file@percent }
\newlabel{sec:vbnc}{{3.4}{19}{VBNC Dormancy}{subsection.3.4}{}}
\newlabel{eq:vbnc}{{5}{20}{VBNC Dormancy}{equation.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces VBNC dormancy. (A)~Sigmoid resuscitation curves for different values of $T_{\text  {vbnc}}$ (9--12\textdegree C). Lower $T_{\text  {vbnc}}$ means the pathogen ``wakes up'' at colder temperatures. Regional SST bands are overlaid: at Alaska winter temperatures ($\sim $3--6\textdegree C), activation is near zero; at Southern California summer temperatures ($\sim $17--20\textdegree C), activation is fully saturated. (B)~Thermal performance curve $g(T)$ with optimum at $T_{\text  {opt}} = 20$\textdegree C and upper lethal limit at $T_{\text  {max}} = 30$\textdegree C. (C)~Combined environmental Vibrio input: the product of VBNC activation $\times $ thermal performance $\times $ $P_{\text  {env,max}}$, showing a bell-shaped input curve whose rising limb depends on $T_{\text  {vbnc}}$.}}{20}{figure.caption.16}\protected@file@percent }
\newlabel{fig:fig_D04}{{16}{20}{VBNC dormancy. (A)~Sigmoid resuscitation curves for different values of $T_{\text {vbnc}}$ (9--12\textdegree C). Lower $T_{\text {vbnc}}$ means the pathogen ``wakes up'' at colder temperatures. Regional SST bands are overlaid: at Alaska winter temperatures ($\sim $3--6\textdegree C), activation is near zero; at Southern California summer temperatures ($\sim $17--20\textdegree C), activation is fully saturated. (B)~Thermal performance curve $g(T)$ with optimum at $T_{\text {opt}} = 20$\textdegree C and upper lethal limit at $T_{\text {max}} = 30$\textdegree C. (C)~Combined environmental Vibrio input: the product of VBNC activation $\times $ thermal performance $\times $ $P_{\text {env,max}}$, showing a bell-shaped input curve whose rising limb depends on $T_{\text {vbnc}}$}{figure.caption.16}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Arrhenius Temperature Scaling}{20}{subsection.3.5}\protected@file@percent }
\newlabel{sec:arrhenius}{{3.5}{20}{Arrhenius Temperature Scaling}{subsection.3.5}{}}
\newlabel{eq:arrhenius}{{6}{20}{Arrhenius Temperature Scaling}{equation.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Arrhenius temperature dependence. (A)~Normalized transition rates relative to $T_{\text  {ref}} = 20$\textdegree C. The steepest temperature sensitivities are for $\text  {I}_1 \to \text  {I}_2$ progression and shedding ($E_a/R = 5000$~K); the shallowest is for $\text  {I}_2 \to $ D mortality ($E_a/R = 2000$~K). (B)~Mean stage durations versus temperature: incubation (E) shortens from $\sim $9 days at 5\textdegree C to $\sim $3.5 days at 25\textdegree C. (C)~Total exposure-to-death duration: $\sim $17.5 days at 5\textdegree C versus $\sim $7--8 days at 25\textdegree C, with a reference value of 11.6 days at 13\textdegree C.}}{21}{figure.caption.17}\protected@file@percent }
\newlabel{fig:fig_D05}{{17}{21}{Arrhenius temperature dependence. (A)~Normalized transition rates relative to $T_{\text {ref}} = 20$\textdegree C. The steepest temperature sensitivities are for $\text {I}_1 \to \text {I}_2$ progression and shedding ($E_a/R = 5000$~K); the shallowest is for $\text {I}_2 \to $ D mortality ($E_a/R = 2000$~K). (B)~Mean stage durations versus temperature: incubation (E) shortens from $\sim $9 days at 5\textdegree C to $\sim $3.5 days at 25\textdegree C. (C)~Total exposure-to-death duration: $\sim $17.5 days at 5\textdegree C versus $\sim $7--8 days at 25\textdegree C, with a reference value of 11.6 days at 13\textdegree C}{figure.caption.17}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.6}Temperature-Dependent Vibrio Decay}{21}{subsection.3.6}\protected@file@percent }
\newlabel{sec:vibrio_decay}{{3.6}{21}{Temperature-Dependent Vibrio Decay}{subsection.3.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Temperature-dependent Vibrio decay. (A)~Decay rate $\xi $ versus temperature: maximum at cold temperatures ($\xi (10\text  {\textdegree C}) = 1.0$~d$^{-1}$) and reduced at warm temperatures ($\xi (20\text  {\textdegree C}) = 0.33$~d$^{-1}$). (B)~The corresponding half-life: Vibrio persists $\sim $0.7 days in cold water but $\sim $2.1 days in warm water---a 3$\times $ difference. Regional summer SST bands are overlaid: Alaska (fast decay), PNW (intermediate), Southern California (slow decay, longest persistence).}}{22}{figure.caption.18}\protected@file@percent }
\newlabel{fig:fig_D06}{{18}{22}{Temperature-dependent Vibrio decay. (A)~Decay rate $\xi $ versus temperature: maximum at cold temperatures ($\xi (10\text {\textdegree C}) = 1.0$~d$^{-1}$) and reduced at warm temperatures ($\xi (20\text {\textdegree C}) = 0.33$~d$^{-1}$). (B)~The corresponding half-life: Vibrio persists $\sim $0.7 days in cold water but $\sim $2.1 days in warm water---a 3$\times $ difference. Regional summer SST bands are overlaid: Alaska (fast decay), PNW (intermediate), Southern California (slow decay, longest persistence)}{figure.caption.18}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.7}Pathogen Thermal Adaptation}{22}{subsection.3.7}\protected@file@percent }
\newlabel{sec:thermal_adapt}{{3.7}{22}{Pathogen Thermal Adaptation}{subsection.3.7}{}}
\newlabel{eq:adapt}{{7}{22}{Pathogen Thermal Adaptation}{equation.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Pathogen thermal adaptation. The figure illustrates how the VBNC threshold temperature $T_{\text  {vbnc}}$ evolves toward cold tolerance at different rates depending on the local thermal regime. Cold northern sites (Alaska) drive more rapid adaptation toward lower $T_{\text  {vbnc}}$ values, while warm southern sites experience little selective pressure for cold tolerance. The floor parameter prevents unrealistic values.}}{23}{figure.caption.19}\protected@file@percent }
\newlabel{fig:fig_D07}{{19}{23}{Pathogen thermal adaptation. The figure illustrates how the VBNC threshold temperature $T_{\text {vbnc}}$ evolves toward cold tolerance at different rates depending on the local thermal regime. Cold northern sites (Alaska) drive more rapid adaptation toward lower $T_{\text {vbnc}}$ values, while warm southern sites experience little selective pressure for cold tolerance. The floor parameter prevents unrealistic values}{figure.caption.19}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.8}Community Virulence Evolution}{23}{subsection.3.8}\protected@file@percent }
\newlabel{sec:virulence}{{3.8}{23}{Community Virulence Evolution}{subsection.3.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Community virulence evolution. (A)~The optimal virulence surface as a function of temperature and host density ($N/K$). Higher temperatures and higher densities select for higher virulence. Contour lines show iso-virulence curves. (B)~The virulence-transmission trade-off: shedding ($\alpha = 1.5$), progression ($\alpha = 1.0$), and kill rate ($\alpha = 2.0$) scale as power functions of virulence with different exponents, creating the trade-off. (C)~Virulence trajectories for three representative environments: warm/dense (SoCal) maintains high virulence ($\sim $0.3), cool/moderate (PNW) settles at intermediate levels ($\sim $0.15), and cold/sparse (Alaska) drives virulence to very low values ($\sim $0.05). A population crash around years 1--3 is marked.}}{23}{figure.caption.20}\protected@file@percent }
\newlabel{fig:fig_D08}{{20}{23}{Community virulence evolution. (A)~The optimal virulence surface as a function of temperature and host density ($N/K$). Higher temperatures and higher densities select for higher virulence. Contour lines show iso-virulence curves. (B)~The virulence-transmission trade-off: shedding ($\alpha = 1.5$), progression ($\alpha = 1.0$), and kill rate ($\alpha = 2.0$) scale as power functions of virulence with different exponents, creating the trade-off. (C)~Virulence trajectories for three representative environments: warm/dense (SoCal) maintains high virulence ($\sim $0.3), cool/moderate (PNW) settles at intermediate levels ($\sim $0.15), and cold/sparse (Alaska) drives virulence to very low values ($\sim $0.05). A population crash around years 1--3 is marked}{figure.caption.20}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.9}Salinity-Based Vibrio Suppression}{24}{subsection.3.9}\protected@file@percent }
\newlabel{sec:salinity_modifier}{{3.9}{24}{Salinity-Based Vibrio Suppression}{subsection.3.9}{}}
\newlabel{eq:sal}{{8}{24}{Salinity-Based Vibrio Suppression}{equation.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces Freshwater refugia. (A)~The salinity modifier function: zero below 10~psu, quadratic ramp to 1.0 at 28~psu. (B)~Two-layer salinity model schematic: WOA23 baseline minus latitude/enclosedness-dependent freshwater depression, with melt pulse peaking around June 15. (C)~Seasonal salinity at three representative sites: Monterey (open coast, $\sim $33~psu year-round, $S_{\text  {sal}} \approx 1$), Puget Sound (moderate, slight summer dip), and Howe Sound glacial fjord (dramatic summer crash to $\sim $10~psu, $S_{\text  {sal}} < 0.5$). The fjord becomes a ``freshwater refugium'' where Vibrio is suppressed precisely when summer warmth would otherwise promote disease.}}{24}{figure.caption.21}\protected@file@percent }
\newlabel{fig:fig_D10}{{21}{24}{Freshwater refugia. (A)~The salinity modifier function: zero below 10~psu, quadratic ramp to 1.0 at 28~psu. (B)~Two-layer salinity model schematic: WOA23 baseline minus latitude/enclosedness-dependent freshwater depression, with melt pulse peaking around June 15. (C)~Seasonal salinity at three representative sites: Monterey (open coast, $\sim $33~psu year-round, $S_{\text {sal}} \approx 1$), Puget Sound (moderate, slight summer dip), and Howe Sound glacial fjord (dramatic summer crash to $\sim $10~psu, $S_{\text {sal}} < 0.5$). The fjord becomes a ``freshwater refugium'' where Vibrio is suppressed precisely when summer warmth would otherwise promote disease}{figure.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.10}Basic Reproduction Number and Sensitivity}{24}{subsection.3.10}\protected@file@percent }
\newlabel{sec:r0}{{3.10}{24}{Basic Reproduction Number and Sensitivity}{subsection.3.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces $R_0$ sensitivity analysis. (A)~$R_0$ versus temperature for three flushing rates ($\varphi = 0.01, 0.02, 0.05$). $R_0$ increases with temperature but remains below the epidemic threshold ($R_0 = 1$) in the absence of the environmental reservoir and wavefront mechanism. (B)~$R_0$ versus host density at $T = 15$\textdegree C: weak dependence. (C)~Parameter space map showing the narrow ``epidemic window'' in the low-flushing, high-temperature corner. Epidemics require both warm temperatures and low flushing---conditions found primarily in enclosed warm-water embayments.}}{25}{figure.caption.22}\protected@file@percent }
\newlabel{fig:fig_D11}{{22}{25}{$R_0$ sensitivity analysis. (A)~$R_0$ versus temperature for three flushing rates ($\varphi = 0.01, 0.02, 0.05$). $R_0$ increases with temperature but remains below the epidemic threshold ($R_0 = 1$) in the absence of the environmental reservoir and wavefront mechanism. (B)~$R_0$ versus host density at $T = 15$\textdegree C: weak dependence. (C)~Parameter space map showing the narrow ``epidemic window'' in the low-flushing, high-temperature corner. Epidemics require both warm temperatures and low flushing---conditions found primarily in enclosed warm-water embayments}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.11}Single-Node Epidemic Demonstration}{25}{subsection.3.11}\protected@file@percent }
\newlabel{sec:single_node}{{3.11}{25}{Single-Node Epidemic Demonstration}{subsection.3.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces Single-node epidemic demonstration. The figure shows the time course of a simulated epidemic at a single node, including compartment trajectories (S, E, $\text  {I}_1$, $\text  {I}_2$, D), environmental Vibrio concentration, and the role of temperature forcing in modulating disease dynamics. The epidemic shows a characteristic rapid initial spread driven by host-amplification feedback, followed by decline as the susceptible pool is depleted.}}{25}{figure.caption.23}\protected@file@percent }
\newlabel{fig:fig_D09}{{23}{25}{Single-node epidemic demonstration. The figure shows the time course of a simulated epidemic at a single node, including compartment trajectories (S, E, $\text {I}_1$, $\text {I}_2$, D), environmental Vibrio concentration, and the role of temperature forcing in modulating disease dynamics. The epidemic shows a characteristic rapid initial spread driven by host-amplification feedback, followed by decline as the susceptible pool is depleted}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces Disease dynamics summary. A comprehensive overview panel integrating the key disease mechanisms---compartmental flow, environmental Vibrio pool, temperature dependence, salinity modification, and spatial dispersal---into a single conceptual framework showing how they interact to produce the observed spatiotemporal pattern of SSWD epidemics across the 896-node network.}}{26}{figure.caption.24}\protected@file@percent }
\newlabel{fig:fig_D12}{{24}{26}{Disease dynamics summary. A comprehensive overview panel integrating the key disease mechanisms---compartmental flow, environmental Vibrio pool, temperature dependence, salinity modification, and spatial dispersal---into a single conceptual framework showing how they interact to produce the observed spatiotemporal pattern of SSWD epidemics across the 896-node network}{figure.caption.24}{}}
