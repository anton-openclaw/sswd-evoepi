\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}Overall Performance: First Per-Site Victory}{2}{subsection.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces RMSE performance comparison across W135-W142 runs. W142 (highlighted in orange) achieves the first per-site flushing configuration to outperform uniform baselines. Horizontal lines show W117 (uniform, blue) and W129 (per-site without larval retention, green) baselines.}}{2}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:rmse_comparison}{{1}{2}{RMSE performance comparison across W135-W142 runs. W142 (highlighted in orange) achieves the first per-site flushing configuration to outperform uniform baselines. Horizontal lines show W117 (uniform, blue) and W129 (per-site without larval retention, green) baselines}{figure.caption.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Regional Recovery Patterns}{3}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Regional recovery comparison showing the evolution from uniform (W117) to per-site without larval retention (W129) to the optimized per-site approach (W142). Note the logarithmic scale due to the wide range of target values.}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:regional_comparison}{{2}{3}{Regional recovery comparison showing the evolution from uniform (W117) to per-site without larval retention (W129) to the optimized per-site approach (W142). Note the logarithmic scale due to the wide range of target values}{figure.caption.3}{}}
