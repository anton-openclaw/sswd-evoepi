\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Effect of n\_connectivity parameter on RMSE. The U-shaped relationship indicates an optimal intermediate value, with n\_connectivity = 0.5 yielding the best performance among tested values.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:n_connectivity}{{3}{4}{Effect of n\_connectivity parameter on RMSE. The U-shaped relationship indicates an optimal intermediate value, with n\_connectivity = 0.5 yielding the best performance among tested values}{figure.caption.4}{}}
